{
  "name": "@openduo/duoduo-widgets",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "description": "Interactive web widgets that give AI agents a visual voice",
  "author": "OpenDuo <noreply@openduo.ai>",
  "license": "MIT",
  "homepage": "https://openduo.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/aidgets/duoduo-widgets"
  },
  "bin": {
    "duoduo-widget": "dist/duoduo-widget.js"
  },
  "scripts": {
    "build": "node scripts/build-cli.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "deploy": "cd service && npx wrangler deploy",
    "dev": "cd service && npx wrangler dev"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "esbuild": "^0.25.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
